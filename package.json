{
  "name": "down-below-with-dr-didi",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "postinstall": "prisma generate",
    "predev": "prisma generate",
    "pretest": "prisma generate",
    "prestart": "prisma generate",
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "pnpm test:unit",
    "test:unit": "jest --runInBand --testPathIgnorePatterns=/integration/",
    "test:integration": "jest src/__tests__/integration --runInBand --detectOpenHandles --testTimeout=30000",
    "test:watch": "jest --watch --testPathIgnorePatterns=/integration/",
    "test:coverage": "jest --coverage",
    "verify:release": "pnpm exec tsc --noEmit && pnpm lint && pnpm test:unit && pnpm test:integration",
    "release:migrate": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "node prisma/seed.mjs",
    "db:studio": "prisma studio",
    "storage:cors": "node --env-file=.env scripts/configure-r2-cors.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1044.0",
    "@aws-sdk/lib-storage": "^3.1044.0",
    "@aws-sdk/s3-request-presigner": "^3.1044.0",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcrypt": "^6.0.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "jose": "^6.2.3",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "pg": "^8.20.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.74.0",
    "resend": "^6.12.4",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@next/env": "^16.2.4",
    "@tailwindcss/postcss": "^4",
    "@types/bcrypt": "^6.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jest": "^29.7.0",
    "jest-environment-node": "^29.7.0",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "ts-jest": "^29.1.0",
    "typescript": "^5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "bcrypt",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  }
}
