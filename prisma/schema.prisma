generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "cockroachdb"
}

model AdminUser {
  id                    String                 @id @default(cuid())
  email                 String                 @unique
  name                  String?
  role                  AdminRole
  isActive              Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  phone                 String?
  passwordHash          String?
  lastLoginAt           DateTime?
  auditLogs             AuditLog[]
  mediaAssets           MediaAsset[]
  updatedSiteSettings   SiteSettings[]         @relation("SiteSettingsUpdatedBy")
  vaultResponses        VaultResponse[]
  vaultSubmissionEvents VaultSubmissionEvent[] @relation("VaultEventAdminActor")
}

model SiteSettings {
  id              String     @id @default(cuid())
  scope           String     @unique @default("global")
  siteName        String
  tagline         String
  motto           String
  siteUrl         String
  primaryWhatsapp String
  contactEmail    String
  heroHeadline    String
  heroBody        String
  heroImageUrl    String?
  heroImageAlt    String?
  footerBlurb     String
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  updatedById     String?
  updatedBy       AdminUser? @relation("SiteSettingsUpdatedBy", fields: [updatedById], references: [id])
}

model SiteAlert {
  id              String    @id @default(cuid())
  text            String
  speed           Int       @default(100)
  durationSeconds Int       @default(22)
  isActive        Boolean   @default(true)
  startsAt        DateTime  @default(now())
  endsAt          DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([isActive, startsAt, endsAt])
  @@index([createdAt])
}

model MediaAsset {
  id          String         @id @default(cuid())
  label       String
  storageKey  String         @unique
  bucket      String
  url         String
  mimeType    String
  sizeBytes   Int
  kind        MediaAssetKind
  altText     String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  createdById String?
  createdBy   AdminUser?     @relation(fields: [createdById], references: [id])
}

model User {
  id                     String                 @id @default(cuid())
  email                  String                 @unique
  displayName            String
  passwordHash           String
  isActive               Boolean                @default(true)
  emailVerified          Boolean                @default(false)
  emailVerifyToken       String?                @unique
  resetToken             String?                @unique
  resetTokenExpiry       DateTime?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  phone                  String?
  role                   String                 @default("member")
  phoneVerifyCode        String?
  phoneVerifyExpiry      DateTime?
  lastActivityAt         DateTime               @default(now())
  failedLoginAttempts    Int                    @default(0)
  lockoutUntil           DateTime?
  emailVerifyTokenExpiry DateTime?
  auditLogs              AuditLog[]
  notifications          UserNotification[]
  vaultSubmissions       VaultSubmission[]
  vaultEvents            VaultSubmissionEvent[] @relation("VaultEventUserActor")
  eventLikes             EventLike[]
  eventComments          EventComment[]
  reviews                Review[]
  reviewHelpfuls         ReviewHelpful[]

  @@index([isActive])
  @@index([role])
  @@index([lastActivityAt])
  @@index([isActive], map: "idx_user_isActive")
  @@index([role], map: "idx_user_role")
}

model AuditLog {
  id         String     @id @default(cuid())
  action     String
  entityType String
  entityId   String?
  actorEmail String
  actorRole  AdminRole
  summary    String
  metadata   Json?
  createdAt  DateTime   @default(now())
  actorId    String?
  userId     String?
  ipAddress  String?
  userAgent  String?
  success    Boolean    @default(true)
  actor      AdminUser? @relation(fields: [actorId], references: [id])
  user       User?      @relation(fields: [userId], references: [id])
}

model VaultSubmission {
  id               String                 @id @default(cuid())
  category         String
  question         String
  status           VaultSubmissionStatus  @default(new)
  moderationNotes  String?
  approvedFaqTitle String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  source           VaultSubmissionSource  @default(app_authenticated)
  userId           String?
  responses        VaultResponse[]
  user             User?                  @relation(fields: [userId], references: [id])
  events           VaultSubmissionEvent[]

  @@index([createdAt])
  @@index([status, createdAt])
  @@index([userId, createdAt])
}

model VaultResponse {
  id               String          @id @default(cuid())
  submissionId     String
  responseBody     String
  responderAdminId String?
  responderRole    AdminRole
  deliveredAt      DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  responderAdmin   AdminUser?      @relation(fields: [responderAdminId], references: [id])
  submission       VaultSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId, createdAt])
  @@index([responderAdminId])
}

model UserNotification {
  id         String    @id @default(cuid())
  userId     String
  type       String
  title      String
  body       String
  entityType String?
  entityId   String?
  isRead     Boolean   @default(false)
  readAt     DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([entityType, entityId])
}

model VaultSubmissionEvent {
  id           String          @id @default(cuid())
  submissionId String
  actorType    VaultActorType
  actorUserId  String?
  actorAdminId String?
  eventType    String
  metadata     Json?
  createdAt    DateTime        @default(now())
  actorAdmin   AdminUser?      @relation("VaultEventAdminActor", fields: [actorAdminId], references: [id])
  actorUser    User?           @relation("VaultEventUserActor", fields: [actorUserId], references: [id])
  submission   VaultSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId, createdAt])
  @@index([actorType, createdAt])
}

model Article {
  id            String            @id @default(cuid())
  slug          String            @unique
  title         String
  excerpt       String
  content       String
  category      String
  coverImageUrl String?
  readTime      Int               @default(5)
  status        PublicationStatus @default(draft)
  publishedAt   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model OutreachEvent {
  id             String            @id @default(cuid())
  slug           String            @unique
  title          String
  summary        String
  body           String?
  coverImageUrl  String?
  coverImageAlt  String?
  communityLabel String?
  location       String?
  scheduledAt    DateTime?
  endedAt        DateTime?
  streamUrl      String?
  streamProvider String?
  isLive         Boolean           @default(false)
  engagementEnabled Boolean        @default(true)
  status         PublicationStatus @default(draft)
  publishedAt    DateTime?
  sortOrder      Int               @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  likes          EventLike[]
  comments       EventComment[]

  @@index([status, scheduledAt])
  @@index([sortOrder, createdAt])
}

model EventLike {
  id        String       @id @default(cuid())
  eventId   String
  userId    String
  createdAt DateTime     @default(now())

  event     OutreachEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

model EventComment {
  id          String        @id @default(cuid())
  eventId     String
  userId      String
  displayName String
  body        String
  status      CommentStatus @default(visible)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  event       OutreachEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([eventId, status, createdAt])
  @@index([userId, createdAt])
}

model ContactSubmission {
  id            String   @id @default(cuid())
  firstName     String
  lastName      String
  email         String
  phone         String?
  preferredDate String?
  preferredTime String?
  message       String
  createdAt     DateTime @default(now())
}

model Review {
  id                    String            @id @default(cuid())
  displayName           String
  roleLabel             String?
  location              String?
  rating                Int               @default(5)
  body                  String
  status                PublicationStatus @default(draft)
  source                ReviewSource      @default(public_submission)
  sortOrder             Int               @default(0)
  userId                String?
  adminReply            String?
  adminReplyAuthorEmail String?
  adminRepliedAt        DateTime?
  publishedAt           DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  user                  User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  helpfuls              ReviewHelpful[]

  @@index([status, sortOrder, createdAt])
  @@index([userId, createdAt])
}

model ReviewHelpful {
  id         String   @id @default(cuid())
  reviewId   String
  userId     String?
  visitorKey String?
  createdAt  DateTime @default(now())
  review     Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reviewId, userId])
  @@unique([reviewId, visitorKey])
  @@index([reviewId])
  @@index([userId])
  @@index([visitorKey])
}

model TeamMember {
  id          String            @id @default(cuid())
  slug        String            @unique
  name        String
  role        String
  tier        TeamTier
  sortOrder   Int               @default(0)
  credentials String
  bio         String
  imageUrl    String?
  imageAlt    String?
  status      PublicationStatus @default(published)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model GalleryImage {
  id          String            @id @default(cuid())
  slug        String            @unique
  title       String
  description String
  caption     String?
  imageUrl    String
  imageAlt    String
  category    GalleryCategory
  eventName   String?
  location    String?
  capturedAt  DateTime?
  status      PublicationStatus @default(published)
  sortOrder   Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model PodcastEpisode {
  id                String            @id @default(cuid())
  slug              String            @unique
  title             String
  summary           String
  description       String
  audioUrl          String
  audioSize         Int?
  audioType         String?
  duration          Int?
  coverImage        String?
  guestName         String?
  topicTags         Json?
  transcript        String?
  externalSourceUrl String?
  publishedAt       DateTime?
  sortOrder         Int               @default(0)
  status            PublicationStatus @default(published)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

enum AdminRole {
  super_admin
  editor
  moderator
  founder_admin
}

enum PublicationStatus {
  draft
  published
  archived
}

enum CommentStatus {
  visible
  hidden
  flagged
}

enum MediaAssetKind {
  image
  document
  video
  other
  audio
}

enum VaultSubmissionStatus {
  new
  reviewed
  answered_privately
  approved_for_faq
  archived
}

enum VaultSubmissionSource {
  app_authenticated
  whatsapp_import
  manual_admin
}

enum VaultActorType {
  user
  admin
  system
}

enum ReviewSource {
  public_submission
  admin_created
  seed
}

enum TeamTier {
  founder
  leadership
  core
}

enum GalleryCategory {
  outreach
  event
  team
  community
  facility
}

enum crdb_internal_region {
  gcp_europe_west3 @map("gcp-europe-west3")
}
